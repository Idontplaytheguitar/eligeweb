# Database
DATABASE_URL="postgresql://user:password@localhost:5432/elige_db?schema=public"

# Admin Authentication
ADMIN_PASSWORD="tu-contraseña-segura"
ADMIN_EMAIL="contacto@estudioelige.com"

# SMTP (Nodemailer)
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_USER="contacto@estudioelige.com"
SMTP_PASS="tu-smtp-password"

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN="tu-access-token"
MERCADOPAGO_PUBLIC_KEY="tu-public-key"

# App URL
NEXT_PUBLIC_APP_URL="https://estudioelige.com"

# OpenAI (opcional - para mejora de texto con IA)
# OPENAI_API_KEY=sk-...

# Google Calendar (opcional - para crear eventos con Meet)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/callback
# GOOGLE_REFRESH_TOKEN=
