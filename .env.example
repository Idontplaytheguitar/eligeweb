# Database
DATABASE_URL="postgresql://user:password@localhost:5432/elige_db?schema=public"

# Admin Authentication
ADMIN_PASSWORD="tu-contraseña-segura"
ADMIN_EMAIL="contacto@estudioelige.com"

# SMTP (Nodemailer)
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_USER="contacto@estudioelige.com"
SMTP_PASS="tu-smtp-password"

# MercadoPago — OAuth Connect (app registrada en developers.mercadopago.com)
# La dueña conecta su cuenta MP desde el panel /admin/configuracion.
MP_CLIENT_ID=""
MP_CLIENT_SECRET=""
MP_OAUTH_REDIRECT_URI="https://estudioelige.com/api/mercadopago/oauth/callback"

# Cifrado de tokens MP guardados en DB (32 bytes en hex → 64 caracteres)
# Generar con: openssl rand -hex 32
MP_TOKEN_ENCRYPTION_KEY=""

# App URL
NEXT_PUBLIC_APP_URL="https://estudioelige.com"

# IA — Google Gemini (para "Mejorar con IA" en editor de blog)
GOOGLE_GENERATIVE_AI_API_KEY=""
# GEMINI_MODEL="gemini-2.0-flash"  # opcional, default: gemini-2.0-flash

# Google Calendar (opcional - para crear eventos con Meet)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/callback
# GOOGLE_REFRESH_TOKEN=

# Cloudinary (necesario para subir imágenes y archivos de cursos)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="tu-cloud-name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="estudioelige"
